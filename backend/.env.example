# ===========================
# CONFIGURATION POSTGRESQL
# ===========================

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mamutuelle
DB_USERNAME=mamutuelle_user
DB_PASSWORD=mamutuelle_pass

# ===========================
# CONFIGURATION LARAVEL
# ===========================

APP_NAME="MaMutuelle"
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===========================
# CACHE CONFIGURATION
# ===========================

CACHE_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ===========================
# SESSION CONFIGURATION
# ===========================

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ===========================
# JWT CONFIGURATION
# ===========================

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGORITHM=HS256
JWT_ALGO=HS256

# ===========================
# MAIL CONFIGURATION
# ===========================

MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mamutuelle.fr"
MAIL_FROM_NAME="${APP_NAME}"

# ===========================
# QUEUE CONFIGURATION
# ===========================

QUEUE_CONNECTION=sync

# ===========================
# REDIS CONFIGURATION
# ===========================

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================
# AWS CONFIGURATION (optionnel)
# ===========================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
